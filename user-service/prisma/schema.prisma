generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  created_at DateTime  @default(now())

  api_key  api_key?
  sessions session[]
}

model api_key {
  id         String   @id @default(uuid())
  user_id    String   @unique
  prefix     String   @unique
  key_hash   String   @unique
  created_at DateTime @default(now())

  user user @relation(fields: [user_id], references: [id])
}

model session {
  id         String      @id
  user_id    String
  started_at DateTime
  ended_at   DateTime

  user       user        @relation(fields: [user_id], references: [id])
  attentions attention[]
}

model attention {
  id          String   @id @default(uuid())
  session_id  String?
  focus       Boolean
  teta        Float
  alpha       Float
  distance    Float
  gaze_vector Float[]
  created_at  DateTime @default(now())

  session session? @relation(fields: [session_id], references: [id])
}
