{
  "name": "vas-attention",
  "version": "1.0.0",
  "description": "Visual Attention System — embeddable monitoring widget",
  "type": "module",
  "main": "./dist/vas-attention.umd.cjs",
  "module": "./dist/vas-attention.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vas-attention.js",
      "require": "./dist/vas-attention.umd.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vue-tsc --noEmit && vite build"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^2.2.0"
  }
}
